# ============================================================
# .gitignore — Regalele Lencería Front (React + Vite)
# ============================================================

# ---- Dependencias ----
node_modules/
.pnpm-store/
.yarn/

# ---- Build / output ----
dist/
dist-ssr/
build/

# ---- Vite ----
.vite/
vite.config.ts.timestamp-*

# ---- Entorno / secretos ----
.env
.env.local
.env.*.local
.env.production
.env.development

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ---- Editor / IDE ----
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ---- TypeScript ----
*.tsbuildinfo
tsconfig.tsbuildinfo

# ---- Docker ----
# Mantener Dockerfile y docker-compose.yml pero ignorar datos de volumen
*.dockerignore

# ---- Base de datos (importante: no subir el dump si tiene datos sensibles) ----
# Comentar la siguiente línea si quieres versionar el SQL
# regalele_base.sql

# ---- Uploads de productos (generados por el sistema) ----
upload/
public/upload/

# ---- Cache ----
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# ---- Test ----
coverage/
.nyc_output

# ---- Misc ----
*.local
*.bak
*.tmp
*.swp
~$*
